{
    "kind": "collectionType",
    "collectionName": "categories",
    "info": {
        "singularName": "category",
        "pluralName": "categories",
        "displayName": "Categories",
        "description": "Organize your content into categories"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "unique": false
        },
        "posts": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::post.post",
            "mappedBy": "category"
        }
    }
}
